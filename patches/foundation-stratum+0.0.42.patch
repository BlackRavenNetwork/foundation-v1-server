+    Buffer.from([0x6a, 0x24, 0xaa, 0x21, 0xa9, 0xed]),
+    commitment,
+  ]);
+};
+
+// Coinbase witness stack (32-byte nonce)
+exports.buildCoinbaseWitness = function(witnessNonce) {
+  return Buffer.concat([
+    Buffer.from([0x01]),
+    Buffer.from([0x20]),
+    witnessNonce,
+  ]);
+};
+
+// Segwit coinbase txid for header merkle (excludes witness)
+exports.coinbaseTxHash = function(coinbaseBuffer) {
+  try {
+    return bitcoin.Transaction.fromBuffer(coinbaseBuffer).getHash();
+  } catch (err) {
+    return exports.sha256d(coinbaseBuffer);
+  }
+};
