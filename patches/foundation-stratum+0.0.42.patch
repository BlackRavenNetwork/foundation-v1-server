+// BlackRaven / KawPoW coinbase height (OP_n + 0x01 0x01), not BIP34 serializeNumber
+exports.kawpowHeightScript = function(height) {
+  let heightPart;
+  if (height >= 1 && height <= 16) {
+    heightPart = Buffer.from([0x50 + height]);
+  } else {
+    // BIP34 height push for heights above OP_16
+    heightPart = exports.serializeNumber(height);
+  }
+  return Buffer.concat([heightPart, Buffer.from([0x01, 0x01])]);
+};
+
+// Witness merkle root for block template (coinbase witness hash = 0)
+exports.witnessMerkleRoot = function(transactions) {
+  let leaves = [Buffer.alloc(32, 0)];
+  if (transactions && transactions.length > 0) {
+    transactions.forEach((tx) => {
+      const hash = tx.hash || tx.txid;
+      if (hash) {
+        leaves.push(exports.uint256BufferFromHash(hash));
+      }
+    });
+  }
+  while (leaves.length > 1) {
+    if (leaves.length % 2 !== 0) {
+      leaves.push(leaves[leaves.length - 1]);
+    }
+    const next = [];
+    for (let i = 0; i < leaves.length; i += 2) {
+      next.push(exports.sha256d(Buffer.concat([leaves[i], leaves[i + 1]])));
+    }
+    leaves = next;
+  }
+  return leaves[0];
+};
+
+// BIP141 witness commitment output (SHA256d(witness_root || nonce))
+exports.buildWitnessCommitment = function(witnessRoot, witnessNonce) {
+  const commitment = exports.sha256d(Buffer.concat([witnessRoot, witnessNonce]));
